<launch>
    <node
        pkg="ratslam"
        exec="ratslam_lv"
        name="ratslam_view_template"
        output="screen">
        <param name="use_sim_time" value="true" />
        <param name="topic_root" value="/newcollege" />
        <param from="$(find-pkg-share ratslam)/config/config_oxford_newcollege.yaml" />
    </node>

    <node
        pkg="ratslam"
        exec="ratslam_pc"
        name="ratslam_pose_cells"
        output="screen">
        <param name="use_sim_time" value="true" />
        <param name="topic_root" value="/newcollege" />
        <param name="media_path" value="$(find-pkg-share ratslam)/media" />
        <param name="image_file" value="irat_sm.tga" />
        <param from="$(find-pkg-share ratslam)/config/config_oxford_newcollege.yaml" />
    </node>

    <node
        pkg="ratslam"
        exec="ratslam_em"
        name="ratslam_experience_map"
        output="screen">
        <param name="use_sim_time" value="true" />
        <param name="topic_root" value="/newcollege" />
        <param name="media_path" value="$(find-pkg-share ratslam)/media" />
        <param name="image_file" value="irat_sm.tga" />
        <param from="$(find-pkg-share ratslam)/config/config_oxford_newcollege.yaml" />
    </node>
</launch>
